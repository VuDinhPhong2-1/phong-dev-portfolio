rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() &&
        request.auth.token.email in ['vudinhphong.261001@gmail.com'];
    }

    match /visitors/{visitorId} {
      allow create, update: if request.resource.data.visitorId == visitorId;
      allow read, delete: if isAdmin();
    }

    match /sessions/{sessionId} {
      allow create, update: if request.resource.data.sessionId == sessionId;
      allow read, delete: if isAdmin();
    }

    match /events/{eventId} {
      allow create: if request.resource.data.type is string &&
        request.resource.data.visitorId is string &&
        request.resource.data.sessionId is string;
      allow update, delete: if false;
      allow read: if isAdmin();
    }

    match /profileConsents/{consentId} {
      allow create: if request.resource.data.visitorId is string &&
        request.resource.data.sessionId is string &&
        request.resource.data.provider is string;
      allow update, delete: if false;
      allow read: if isAdmin();
    }

    match /questions/{questionId} {
      allow create: if request.resource.data.question is string &&
        request.resource.data.alias is string;
      allow read: if isAdmin();
      allow update, delete: if isAdmin();
    }

    match /publicQuestions/{questionId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }
  }
}
